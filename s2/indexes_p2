## 3. JOIN
3.1.
``` sql
SELECT
    co.id AS order_id,
    c.full_name,
    car.license_plate,
    l.address,
    co.status,
    co.total_amount
FROM client_order co
JOIN client c ON c.id = co.id_client
JOIN car ON car.id = co.id_car
JOIN location l ON l.id = co.id_location
ORDER BY co.id
LIMIT 20;
```
![Скриншот](screenshots5/3.1.png)

3.2. 
``` sql
SELECT
    co.id AS order_id,
    e.full_name AS employee_name,
    e.position,
    co.created_date,
    co.status
FROM client_order co
JOIN employee e ON e.id = co.employee_id
ORDER BY co.created_date DESC
LIMIT 20;
```
![Скриншот](screenshots5/3.2.png)

3.3. 
``` sql
SELECT
    co.id AS order_id,
    n.article,
    n.name AS product_name,
    coi.quantity,
    coi.unit_price,
    coi.total_price
FROM client_order co
JOIN client_order_items coi ON coi.id_order = co.id
JOIN product_prices pp ON pp.id = coi.product_price_id
JOIN nomenclature n ON n.article = pp.article
ORDER BY co.id
LIMIT 20;
```
![Скриншот](screenshots5/3.3.png)

3.4. 
``` sql
SELECT
    co.id AS order_id,
    s.name AS service_name,
    cos.quantity,
    cos.unit_price,
    cos.total_price
FROM client_order co
JOIN client_order_services cos ON cos.id_order = co.id
JOIN service_prices sp ON sp.id = cos.service_price_id
JOIN service s ON s.name = sp.service_name
ORDER BY co.id
LIMIT 20;
```
![Скриншот](screenshots5/3.4.png)

3.5. 
``` sql
SELECT
    c.full_name,
    lc.points_balance,
    lr.level_name,
    lr.discount_percent
FROM client c
JOIN loyalty_card lc ON lc.id_client = c.id
JOIN loyalty_rules lr ON lc.points_balance >= lr.min_points
WHERE lr.min_points = (
    SELECT MAX(min_points)
    FROM loyalty_rules lr2
    WHERE lc.points_balance >= lr2.min_points
)
ORDER BY lc.points_balance DESC;
```
![Скриншот](screenshots5/3.5.png)
